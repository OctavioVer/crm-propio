# ─── DATABASE ────────────────────────────────────────────────────────────────
# Dev local (docker-compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/crm_dev?schema=public"
# Railway/Render prod example:
# DATABASE_URL="postgresql://user:pass@host:5432/crm_prod"

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Railway Redis: redis://:password@host:port

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-secret-in-production-min-32-chars-xxxx"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Dev
CORS_ORIGINS="http://localhost:3000"
# Prod: CORS_ORIGINS="https://tuapp.railway.app,https://tudominio.com"

# ─── EMAIL ───────────────────────────────────────────────────────────────────
# Dev: Mailpit (docker-compose)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CRM Pro <noreply@crm.local>"

# Prod con Resend:
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT=465
# SMTP_USER="resend"
# SMTP_PASS="re_xxxxxxxxxxxx"
# SMTP_FROM="CRM Pro <noreply@tudominio.com>"

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── NEXT.JS ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Prod:
# NEXT_PUBLIC_API_URL="https://tu-api.railway.app"
# NEXT_PUBLIC_APP_URL="https://tu-app.railway.app"
